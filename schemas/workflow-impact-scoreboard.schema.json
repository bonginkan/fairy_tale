{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/bonginkan/fairy_tale/schemas/workflow-impact-scoreboard.schema.json",
  "title": "Fairy Tale workflow impact scoreboard",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "scoreboard_id",
    "generated_at_utc",
    "source_refs",
    "entries",
    "routing_eval_bindings"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "artifact_type": {"const": "workflow_impact_scoreboard"},
    "scoreboard_id": {"$ref": "#/$defs/portable_id"},
    "generated_at_utc": {
      "type": "string",
      "format": "date-time",
      "pattern": "Z$"
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/source"}
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/entry"}
    },
    "routing_eval_bindings": {
      "type": "array",
      "items": {"$ref": "#/$defs/routing_eval_binding"}
    }
  },
  "$defs": {
    "portable_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{2,127}$"
    },
    "nonempty_text": {
      "type": "string",
      "pattern": "^(?=.*\\S)[\\s\\S]+$"
    },
    "repo_path": {
      "type": "string",
      "pattern": "^(?=.*\\S)(?!.*[\\u0000-\\u001F\\u007F])(?!/)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*[\\\\:])[^/]+(?:/[^/]+)*$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "nullable_nonnegative_number": {
      "type": ["number", "null"],
      "minimum": 0
    },
    "nullable_nonnegative_integer": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "checked_at", "source_type", "note"],
      "properties": {
        "url": {"type": "string", "format": "uri", "pattern": "^https://"},
        "checked_at": {"type": "string", "format": "date"},
        "source_type": {"enum": ["official", "repository", "public_report"]},
        "note": {"$ref": "#/$defs/nonempty_text"}
      }
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_id",
        "task_kind",
        "task_family",
        "task_id",
        "comparison_mode",
        "comparison_contract",
        "runs",
        "comparison_note"
      ],
      "properties": {
        "entry_id": {"$ref": "#/$defs/portable_id"},
        "task_kind": {"enum": ["benchmark", "normal"]},
        "task_family": {"$ref": "#/$defs/nonempty_text"},
        "task_id": {"$ref": "#/$defs/portable_id"},
        "comparison_mode": {"enum": ["paired_local", "paired_external_baseline", "unpaired"]},
        "comparison_contract": {"$ref": "#/$defs/comparison_contract"},
        "runs": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "items": {"$ref": "#/$defs/run"}
        },
        "comparison_note": {"$ref": "#/$defs/nonempty_text"}
      },
      "allOf": [
        {
          "if": {"properties": {"comparison_mode": {"const": "unpaired"}}},
          "then": {"properties": {"runs": {"minItems": 1, "maxItems": 1}}}
        },
        {
          "if": {"properties": {"comparison_mode": {"enum": ["paired_local", "paired_external_baseline"]}}},
          "then": {
            "properties": {
              "runs": {
                "minItems": 2,
                "maxItems": 2,
                "allOf": [
                  {"contains": {"properties": {"condition": {"const": "baseline"}}}},
                  {"contains": {"properties": {"condition": {"const": "fairy_tale"}}}}
                ]
              }
            }
          }
        }
      ]
    },
    "comparison_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model",
        "effort",
        "prompt_version",
        "scorer_version",
        "sample_ids",
        "max_output_tokens",
        "wall_clock_budget_seconds",
        "tool_budget",
        "budget_unavailable_reason",
        "retry_policy",
        "safety_policy"
      ],
      "properties": {
        "model": {"$ref": "#/$defs/nonempty_text"},
        "effort": {"$ref": "#/$defs/nonempty_text"},
        "prompt_version": {"$ref": "#/$defs/nonempty_text"},
        "scorer_version": {"$ref": "#/$defs/nonempty_text"},
        "sample_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/nonempty_text"}
        },
        "max_output_tokens": {"type": ["integer", "null"], "minimum": 1},
        "wall_clock_budget_seconds": {"type": ["integer", "null"], "minimum": 1},
        "tool_budget": {"type": ["integer", "null"], "minimum": 0},
        "budget_unavailable_reason": {"type": ["string", "null"]},
        "retry_policy": {"$ref": "#/$defs/nonempty_text"},
        "safety_policy": {"$ref": "#/$defs/nonempty_text"}
      }
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_id",
        "condition",
        "source_kind",
        "isolation",
        "metrics",
        "regression",
        "artifact",
        "card_telemetry",
        "validation_evidence"
      ],
      "properties": {
        "run_id": {"$ref": "#/$defs/portable_id"},
        "condition": {"enum": ["baseline", "fairy_tale"]},
        "source_kind": {"enum": ["measured_local", "official_external", "example"]},
        "isolation": {"$ref": "#/$defs/isolation"},
        "metrics": {"$ref": "#/$defs/metrics"},
        "regression": {"$ref": "#/$defs/regression"},
        "artifact": {"$ref": "#/$defs/artifact"},
        "card_telemetry": {
          "type": "array",
          "items": {"$ref": "#/$defs/card_telemetry"}
        },
        "validation_evidence": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/nonempty_text"}
        }
      }
    },
    "isolation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fresh_session", "skill_state", "note"],
      "properties": {
        "fresh_session": {"type": "boolean"},
        "skill_state": {"enum": ["disabled", "enabled", "external", "not_applicable"]},
        "note": {"$ref": "#/$defs/nonempty_text"}
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pass_count",
        "total_count",
        "validation_result",
        "score",
        "score_unit",
        "score_unavailable_reason",
        "elapsed_seconds",
        "elapsed_unavailable_reason",
        "cost_usd",
        "cost_unavailable_reason",
        "tokens",
        "token_unavailable_reason"
      ],
      "properties": {
        "pass_count": {"type": "integer", "minimum": 0},
        "total_count": {"type": "integer", "minimum": 1},
        "validation_result": {"enum": ["pass", "fail"]},
        "score": {"$ref": "#/$defs/nullable_nonnegative_number"},
        "score_unit": {"type": ["string", "null"]},
        "score_unavailable_reason": {"type": ["string", "null"]},
        "elapsed_seconds": {"$ref": "#/$defs/nullable_nonnegative_number"},
        "elapsed_unavailable_reason": {"type": ["string", "null"]},
        "cost_usd": {"$ref": "#/$defs/nullable_nonnegative_number"},
        "cost_unavailable_reason": {"type": ["string", "null"]},
        "tokens": {"$ref": "#/$defs/tokens"},
        "token_unavailable_reason": {"type": ["string", "null"]}
      }
    },
    "tokens": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_tokens",
        "output_tokens",
        "cache_creation_input_tokens",
        "cache_read_input_tokens",
        "total_tokens"
      ],
      "properties": {
        "input_tokens": {"$ref": "#/$defs/nullable_nonnegative_integer"},
        "output_tokens": {"$ref": "#/$defs/nullable_nonnegative_integer"},
        "cache_creation_input_tokens": {"$ref": "#/$defs/nullable_nonnegative_integer"},
        "cache_read_input_tokens": {"$ref": "#/$defs/nullable_nonnegative_integer"},
        "total_tokens": {"$ref": "#/$defs/nullable_nonnegative_integer"}
      }
    },
    "regression": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "note"],
      "properties": {
        "status": {"enum": ["none", "observed", "unknown"]},
        "note": {"$ref": "#/$defs/nonempty_text"}
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "path", "visibility", "disclosure", "sha256"],
      "properties": {
        "kind": {"enum": ["run_output", "example", "routing_eval_ledger"]},
        "path": {"$ref": "#/$defs/repo_path"},
        "visibility": {"enum": ["repository", "private", "local"]},
        "disclosure": {"enum": ["full", "redacted"]},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "card_telemetry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "card_path",
        "fired_count",
        "contribution",
        "attributed_tokens",
        "token_unavailable_reason",
        "evidence_refs"
      ],
      "properties": {
        "card_path": {"$ref": "#/$defs/repo_path"},
        "fired_count": {"type": "integer", "minimum": 1},
        "contribution": {"enum": ["helpful", "neutral", "harmful", "unknown"]},
        "attributed_tokens": {"$ref": "#/$defs/nullable_nonnegative_integer"},
        "token_unavailable_reason": {"type": ["string", "null"]},
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/nonempty_text"}
        }
      }
    },
    "routing_eval_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entry_id", "condition", "ledger_path", "ledger_sha256"],
      "properties": {
        "entry_id": {"$ref": "#/$defs/portable_id"},
        "condition": {"enum": ["baseline", "fairy_tale"]},
        "ledger_path": {"$ref": "#/$defs/repo_path"},
        "ledger_sha256": {"$ref": "#/$defs/sha256"}
      }
    }
  }
}
