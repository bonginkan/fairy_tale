{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/bonginkan/fairy_tale/schemas/e3-execution-ledger.schema.json",
  "title": "E3 execution ledger",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "task_id",
    "objective",
    "acceptance_checks",
    "estimate",
    "max_expansions",
    "confidence_threshold",
    "low_confidence_expansion_candidate",
    "safety_floor",
    "current_level",
    "cached_evidence",
    "attempts",
    "status",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "artifact_type": {
      "const": "e3_execution_ledger"
    },
    "task_id": {
      "$ref": "#/$defs/id"
    },
    "objective": {
      "$ref": "#/$defs/nonemptyString"
    },
    "acceptance_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/acceptanceCheck"
      }
    },
    "estimate": {
      "$ref": "#/$defs/estimate"
    },
    "max_expansions": {
      "type": "integer",
      "minimum": 0,
      "maximum": 2
    },
    "confidence_threshold": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "low_confidence_expansion_candidate": {
      "type": "boolean"
    },
    "safety_floor": {
      "$ref": "#/$defs/safetyFloor"
    },
    "current_level": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3
    },
    "cached_evidence": {
      "$ref": "#/$defs/evidenceRefs"
    },
    "attempts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/attempt"
      }
    },
    "status": {
      "enum": [
        "estimated",
        "active",
        "verified",
        "blocked",
        "exhausted"
      ]
    },
    "summary": {
      "type": "string"
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{2,127}$"
    },
    "nonemptyString": {
      "type": "string",
      "pattern": ".*\\S.*"
    },
    "uniqueStrings": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/nonemptyString"
      }
    },
    "nonemptyUniqueStrings": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/nonemptyString"
      }
    },
    "nonemptyUniqueIds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/id"
      }
    },
    "evidenceRef": {
      "type": "string",
      "pattern": "^(?:https?://[^\\s/]+/\\S+|sha256:[0-9a-f]{64}|(?:run|trace|search|metadata|test|check|file|artifact|log):[A-Za-z0-9][A-Za-z0-9._/@#:+-]{0,255})$"
    },
    "evidenceRefs": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/evidenceRef"
      }
    },
    "nonemptyEvidenceRefs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/evidenceRef"
      }
    },
    "acceptanceCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "description"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "description": {
          "$ref": "#/$defs/nonemptyString"
        }
      }
    },
    "probe": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "count",
        "query",
        "evidence"
      ],
      "properties": {
        "kind": {
          "enum": [
            "none",
            "search",
            "metadata"
          ]
        },
        "count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1
        },
        "query": {
          "type": "string"
        },
        "evidence": {
          "$ref": "#/$defs/evidenceRefs"
        }
      }
    },
    "estimate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "difficulty",
        "scope",
        "risk",
        "confidence",
        "rationale",
        "probe"
      ],
      "properties": {
        "difficulty": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3
        },
        "scope": {
          "$ref": "#/$defs/nonemptyUniqueStrings"
        },
        "risk": {
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "rationale": {
          "$ref": "#/$defs/nonemptyString"
        },
        "probe": {
          "$ref": "#/$defs/probe"
        }
      }
    },
    "safetyFloor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_gates",
        "closure_tier_a_preserved",
        "authority_and_safety_preserved"
      ],
      "properties": {
        "required_gates": {
          "allOf": [
            {
              "$ref": "#/$defs/nonemptyUniqueIds"
            },
            {
              "contains": {
                "const": "validation_plan"
              }
            },
            {
              "contains": {
                "const": "closure_check"
              }
            },
            {
              "contains": {
                "const": "tier_a_recall"
              }
            },
            {
              "contains": {
                "const": "authority_and_safety"
              }
            }
          ]
        },
        "closure_tier_a_preserved": {
          "const": true
        },
        "authority_and_safety_preserved": {
          "const": true
        }
      }
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "result",
        "evidence",
        "notes"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "result": {
          "enum": [
            "pass",
            "fail",
            "blocked",
            "not_run"
          ]
        },
        "evidence": {
          "$ref": "#/$defs/evidenceRefs"
        },
        "notes": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "required": [
              "result"
            ],
            "properties": {
              "result": {
                "enum": [
                  "pass",
                  "fail",
                  "blocked"
                ]
              }
            }
          },
          "then": {
            "properties": {
              "evidence": {
                "$ref": "#/$defs/nonemptyEvidenceRefs"
              }
            }
          }
        }
      ]
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tier",
        "result",
        "checks",
        "notes"
      ],
      "properties": {
        "tier": {
          "enum": [
            "local",
            "focused",
            "full"
          ]
        },
        "result": {
          "enum": [
            "pass",
            "fail",
            "blocked"
          ]
        },
        "checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/check"
          }
        },
        "notes": {
          "$ref": "#/$defs/nonemptyString"
        }
      },
      "allOf": [
        {
          "if": {
            "required": [
              "result"
            ],
            "properties": {
              "result": {
                "const": "pass"
              }
            }
          },
          "then": {
            "properties": {
              "checks": {
                "items": {
                  "required": [
                    "result"
                  ],
                  "properties": {
                    "result": {
                      "const": "pass"
                    }
                  }
                },
                "allOf": [
                  {
                    "contains": {
                      "required": [
                        "id",
                        "result"
                      ],
                      "properties": {
                        "id": {
                          "const": "validation_plan"
                        },
                        "result": {
                          "const": "pass"
                        }
                      }
                    },
                    "minContains": 1,
                    "maxContains": 1
                  },
                  {
                    "contains": {
                      "required": [
                        "id",
                        "result"
                      ],
                      "properties": {
                        "id": {
                          "const": "closure_check"
                        },
                        "result": {
                          "const": "pass"
                        }
                      }
                    },
                    "minContains": 1,
                    "maxContains": 1
                  },
                  {
                    "contains": {
                      "required": [
                        "id",
                        "result"
                      ],
                      "properties": {
                        "id": {
                          "const": "tier_a_recall"
                        },
                        "result": {
                          "const": "pass"
                        }
                      }
                    },
                    "minContains": 1,
                    "maxContains": 1
                  },
                  {
                    "contains": {
                      "required": [
                        "id",
                        "result"
                      ],
                      "properties": {
                        "id": {
                          "const": "authority_and_safety"
                        },
                        "result": {
                          "const": "pass"
                        }
                      }
                    },
                    "minContains": 1,
                    "maxContains": 1
                  }
                ]
              }
            }
          }
        },
        {
          "if": {
            "required": [
              "result"
            ],
            "properties": {
              "result": {
                "const": "fail"
              }
            }
          },
          "then": {
            "properties": {
              "checks": {
                "contains": {
                  "required": [
                    "result"
                  ],
                  "properties": {
                    "result": {
                      "const": "fail"
                    }
                  }
                },
                "minContains": 1
              }
            }
          }
        },
        {
          "if": {
            "required": [
              "result"
            ],
            "properties": {
              "result": {
                "const": "blocked"
              }
            }
          },
          "then": {
            "properties": {
              "checks": {
                "contains": {
                  "required": [
                    "result"
                  ],
                  "properties": {
                    "result": {
                      "const": "blocked"
                    }
                  }
                },
                "minContains": 1
              }
            }
          }
        }
      ]
    },
    "attempt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "index",
        "level",
        "scope",
        "reused_evidence",
        "new_evidence",
        "cost",
        "verification"
      ],
      "properties": {
        "index": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2
        },
        "level": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3
        },
        "scope": {
          "$ref": "#/$defs/nonemptyUniqueStrings"
        },
        "reused_evidence": {
          "$ref": "#/$defs/evidenceRefs"
        },
        "new_evidence": {
          "$ref": "#/$defs/nonemptyEvidenceRefs"
        },
        "cost": {
          "$ref": "#/$defs/cost"
        },
        "verification": {
          "$ref": "#/$defs/verification"
        }
      }
    },
    "cost": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "latency_ms",
        "tokens",
        "tool_calls",
        "inspected_items"
      ],
      "properties": {
        "latency_ms": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "tokens": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "tool_calls": {
          "type": "integer",
          "minimum": 0
        },
        "inspected_items": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
