{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/bonginkan/fairy_tale/schemas/spiral-revolution-ledger.schema.json",
  "title": "Fairy Tale Spiral Revolution Ledger",
  "description": "Exercised record of one spiral-engineering revolution. Unlike a residency presence marker (which only checks that the spec text exists), this ledger is validated for content: evidence-bearing fields must carry concrete references, so a presence-only or placeholder record fails.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "revolution_id",
    "altitude",
    "execution_strand",
    "learning_governance_strand",
    "strand_pairing_evidence",
    "risk",
    "mismatch_repair",
    "validated_governance_template",
    "win_condition",
    "budget_radius",
    "safety_floor",
    "ledger_receipt"
  ],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^1\\.0$" },
    "revolution_id": { "type": "string", "minLength": 1 },
    "altitude": {
      "type": "object",
      "additionalProperties": false,
      "required": ["current", "target", "axis"],
      "properties": {
        "current": { "type": "string", "minLength": 1 },
        "target": { "type": "string", "minLength": 1 },
        "axis": {
          "type": "string",
          "enum": ["autonomy", "abstraction", "scope", "delegation", "capability", "risk_burn_down"]
        }
      }
    },
    "execution_strand": {
      "type": "object",
      "additionalProperties": false,
      "required": ["objective", "engineer_target", "validation_reviews"],
      "properties": {
        "objective": { "type": "string", "minLength": 1 },
        "engineer_target": { "type": "string", "minLength": 1 },
        "validation_reviews": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "learning_governance_strand": {
      "type": "object",
      "additionalProperties": false,
      "required": ["double_loop_evaluation", "governing_variable_change", "next_altitude", "stop_or_descend"],
      "properties": {
        "double_loop_evaluation": { "type": "string", "minLength": 1 },
        "governing_variable_change": { "type": "string", "minLength": 1 },
        "next_altitude": { "type": "string", "minLength": 1 },
        "stop_or_descend": { "type": "string", "minLength": 1 }
      }
    },
    "strand_pairing_evidence": {
      "description": "Base pairs binding the execution and learning strands. Each entry MUST be a concrete reference (URL, commit sha, #issue/PR, or run-/trace- id).",
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["highest_uncertainty", "spike", "burn_down_evidence"],
      "properties": {
        "highest_uncertainty": { "type": "string", "minLength": 1 },
        "spike": { "type": "string", "minLength": 1 },
        "burn_down_evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "mismatch_repair": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mismatches", "repair_action"],
      "properties": {
        "mismatches": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "repair_action": { "type": "string", "minLength": 1 }
      }
    },
    "validated_governance_template": { "type": "string", "minLength": 1 },
    "win_condition": { "type": "string", "minLength": 1 },
    "budget_radius": { "type": "string", "minLength": 1 },
    "safety_floor": { "type": "string", "minLength": 1 },
    "ledger_receipt": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
