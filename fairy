@dataclass(frozen=True)
class Step:
    step_id: str
    label: str
    command: tuple[str, ...]
    credential_keys: frozenset[str] = frozenset()


def python_step(
    step_id: str,
    label: str,
    script: str,
    *args: str,
    credential_keys: frozenset[str] = frozenset(),
) -> Step:
    return Step(
        step_id,
        label,
        (PYTHON, str(ROOT / "scripts" / script), *args),
        credential_keys,
    )


